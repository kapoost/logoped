# Supabase — skopiuj z Settings > API w panelu Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service role — TYLKO server-side, nigdy w kliencie!
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Web Push VAPID — generuj: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BM...
VAPID_PRIVATE_KEY=...
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BM...   # to samo co VAPID_PUBLIC_KEY

# Email nadawcy dla push notifications
VAPID_SUBJECT=mailto:admin@logoped.pl

# URL aplikacji (dla push i auth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
